{
  "productName": "blink1-toy",
  "version": "0.1.0",
  "identifier": "com.todbot.blink1-toy",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "blink(1) Toy",
        "width": 500,
        "height": 500,
        "resizable": false,
        "center": true
      }
    ],
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "category": "Utility",
    "copyright": "Copyright © 2026 Tod Kurt",
    "macOS": {
      "entitlements": "entitlements.plist",
      "frameworks": [],
      "minimumSystemVersion": "10.15",
      "signingIdentity": null
    },
    "windows": {
      "digestAlgorithm": "sha256",
      "certificateThumbprint": null,
      "timestampUrl": "http://timestamp.digicert.com",
      "signCommand": "trusted-signing-cli -e https://eus.codesigning.azure.net/ -a YOUR_ACCOUNT_NAME -c YOUR_CERTIFICATE_PROFILE %1"
    }
  }
}
